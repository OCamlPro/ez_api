(library
 (name wsHttpun)
 (package ez_api)
 (optional)
 (modules wsHttpun)
 (libraries httpun-ws digestif uuidm unix))

(library
 (name wsHttpunLwt)
 (package ez_api)
 (optional)
 (modules wsHttpunLwt)
 (libraries ezAPIServerUtils
  (select wsHttpunLwt.ml from
   (wsHttpun ezLwtSys -> wsHttpunLwt.real.ml)
   (-> wsHttpunLwt.dummy.ml))))

