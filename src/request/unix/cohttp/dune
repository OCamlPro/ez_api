(library
 (name ezCohttp_lwt)
 (public_name ez_api.cohttp_lwt)
 (optional)
 (modules ezCohttp_lwt)
 (libraries cohttp-lwt-unix ezRequest_lwt cohttp_base))

(library
 (name cohttp_eio_tls)
 (public_name ez_api.cohttp_eio_tls)
 (optional)
 (modules cohttp_eio_tls)
 (libraries
  (select cohttp_eio_tls.ml from
   (tls-eio domain-name uri mirage-crypto-rng.unix -> cohttp_eio_tls.tls.ml)
   (-> cohttp_eio_tls.none.ml))))
